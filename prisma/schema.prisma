generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ATHLETE
  ADMIN
}

/** Bloqueio moderado pela plataforma (ADM). */
enum AccountStatus {
  ACTIVE
  BLOCKED
  BANNED
}

enum Sport {
  FOOTBALL
  VOLLEYBALL
  BEACH_TENNIS
  PADEL
  FUTVOLEI
  BASKETBALL
}

enum GroupVisibility {
  PUBLIC
  PRIVATE
}

enum GroupMemberRole {
  PRESIDENT
  VICE_PRESIDENT
  TREASURER
  MODERATOR
  MEMBER
}

enum JoinRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AttendanceStatus {
  GOING
  NOT_GOING
  MAYBE
  /** Confirmação em fila (limite de vagas ou prazo de RSVP). */
  WAITLIST
}

/** Jogo esportivo (times, placar) ou evento social (churrasco, compra de materiais, etc.). */
enum GameKind {
  MATCH
  SOCIAL
}

enum LedgerEntryKind {
  INCOME
  EXPENSE
}

enum GameOutcome {
  WIN
  DRAW
  LOSS
}

/** Lado do rachão (placar Time A x Time B). */
enum GameTeamSide {
  TEAM_A
  TEAM_B
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  phone        String   @unique
  passwordHash String
  fullName     String
  birthDate    DateTime @db.Date
  role           UserRole       @default(ATHLETE)
  accountStatus  AccountStatus @default(ACTIVE)
  moderationReason String?      @db.Text
  moderatedAt      DateTime?

  termsVersion      Int
  privacyVersion    Int
  termsAcceptedAt   DateTime
  privacyAcceptedAt DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  presidentOf         Group[]              @relation("PresidentGroups")
  groupMemberships    GroupMember[]
  groupJoinRequests   GroupJoinRequest[]
  monthlyFeesAsMember MemberMonthlyFee[]   @relation("MonthlyFeeMember")
  monthlyFeesRecorded MemberMonthlyFee[]   @relation("FeeRecorder")
  gamesCreated        GroupGame[]           @relation("GamesCreated")
  gameAttendances     GameAttendance[]
  ledgerEntriesRecorded GroupLedgerEntry[]
  gameScoutStats      GameScoutStat[]

  @@map("users")
}

model LegalDocument {
  id       String @id @default(cuid())
  slug     String
  version  Int
  title    String
  content  String @db.Text
  isActive Boolean @default(false)

  createdAt DateTime @default(now())

  @@unique([slug, version])
  @@index([slug, isActive])
  @@map("legal_documents")
}

model Group {
  id          String          @id @default(cuid())
  publicCode  String          @unique @db.VarChar(6)
  name        String
  visibility  GroupVisibility
  sport       Sport
  presidentId String
  president   User            @relation("PresidentGroups", fields: [presidentId], references: [id])
  /** Link opcional do estatuto ou regulamento externo. */
  statuteUrl        String? @db.VarChar(2000)
  /** Regras / observações locais do grupo (texto livre). */
  localRulesNote    String? @db.Text
  /** Se verdadeiro e o grupo for público, a página «ver perfil» exibe planos, situação de mensalidade etc. */
  richPublicProfile Boolean @default(false)
  /** Permite opção «Talvez» na confirmação de presença em eventos. */
  rsvpAllowMaybe               Boolean @default(true)
  /** Horas antes do início do evento: depois desse instante, «Sim» do próprio membro entra na fila (se houver política de fila). Null = só limite de vagas. */
  rsvpDeadlineHoursBeforeStart Int?
  /** Máximo de confirmados «Sim»; null = sem teto para auto-confirmação. */
  eventMaxParticipants         Int?
  /** Vagas reservadas (ex.: goleiros): reduzem as vagas de auto-confirmação; líderes preenchem. */
  eventReservedSlots           Int     @default(0)

  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  members           GroupMember[]
  joinRequests      GroupJoinRequest[]
  memberMonthlyFees MemberMonthlyFee[]
  games             GroupGame[]
  ledgerEntries     GroupLedgerEntry[]
  feePlans          GroupFeePlan[]
  enabledScoutMetrics GroupEnabledScout[]

  @@map("groups")
}

/** Plano de mensalidade definido pelo grupo (nome + valor). Cada membro escolhe um plano. */
model GroupFeePlan {
  id          String   @id @default(cuid())
  groupId     String
  group       Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  name        String   @db.VarChar(80)
  amountCents Int
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  members     GroupMember[]
  monthlyFees MemberMonthlyFee[]

  @@index([groupId])
  @@map("group_fee_plans")
}

model GroupJoinRequest {
  id          String            @id @default(cuid())
  groupId     String
  group       Group             @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId      String
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  status      JoinRequestStatus @default(PENDING)
  createdAt   DateTime          @default(now())
  respondedAt DateTime?

  @@index([groupId, status])
  @@map("group_join_requests")
}

model GroupMember {
  id        String          @id @default(cuid())
  groupId   String
  group     Group           @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      GroupMemberRole
  joinedAt  DateTime        @default(now())
  feePlanId String?
  feePlan   GroupFeePlan?   @relation(fields: [feePlanId], references: [id], onDelete: SetNull)

  @@unique([groupId, userId])
  @@map("group_members")
}

/** Registro de mensalidade paga no mês (YYYY-MM). Ausência de registro = em aberto. */
model MemberMonthlyFee {
  id               String   @id @default(cuid())
  groupId          String
  group            Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId           String
  user             User     @relation("MonthlyFeeMember", fields: [userId], references: [id], onDelete: Cascade)
  periodMonth      String   @db.VarChar(7)
  feePlanId        String?
  feePlan          GroupFeePlan? @relation(fields: [feePlanId], references: [id], onDelete: SetNull)
  paidAt           DateTime @default(now())
  recordedByUserId String?
  recordedBy       User?    @relation("FeeRecorder", fields: [recordedByUserId], references: [id], onDelete: SetNull)
  ledgerEntry      GroupLedgerEntry?

  @@unique([groupId, userId, periodMonth])
  @@index([groupId, periodMonth])
  @@map("member_monthly_fees")
}

model GroupGame {
  id              String        @id @default(cuid())
  groupId         String
  group           Group         @relation(fields: [groupId], references: [id], onDelete: Cascade)
  kind            GameKind      @default(MATCH)
  title           String        @default("Jogo")
  location        String?
  startsAt        DateTime
  outcome         GameOutcome?
  teamAScore      Int?
  teamBScore      Int?
  createdByUserId String?
  createdBy       User?         @relation("GamesCreated", fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt       DateTime      @default(now())

  attendances GameAttendance[]
  scoutStats  GameScoutStat[]

  @@index([groupId, startsAt])
  @@map("group_games")
}

model GameAttendance {
  id        String           @id @default(cuid())
  gameId    String
  game      GroupGame        @relation(fields: [gameId], references: [id], onDelete: Cascade)
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  status    AttendanceStatus
  teamSide  GameTeamSide?
  /** Quando entrou na fila de espera (ordenar por FIFO). */
  waitlistEnteredAt   DateTime?
  /** Confirmado por líder, pode exceder vagas normais ou reservas. */
  forcedByModerator   Boolean           @default(false)
  updatedAt DateTime         @updatedAt

  @@unique([gameId, userId])
  @@index([gameId, status])
  @@map("game_attendances")
}

/** Lançamento de caixa do grupo (entrada ou saída, em centavos). */
model GroupLedgerEntry {
  id                 String           @id @default(cuid())
  groupId            String
  group              Group            @relation(fields: [groupId], references: [id], onDelete: Cascade)
  kind               LedgerEntryKind
  amountCents        Int
  description        String           @db.VarChar(500)
  occurredAt         DateTime
  recordedByUserId   String?
  recordedBy         User?            @relation(fields: [recordedByUserId], references: [id], onDelete: SetNull)
  memberMonthlyFeeId String?          @unique
  memberMonthlyFee   MemberMonthlyFee? @relation(fields: [memberMonthlyFeeId], references: [id], onDelete: Cascade)
  createdAt          DateTime         @default(now())

  @@index([groupId, occurredAt])
  @@map("group_ledger_entries")
}

/** Métrica opcional de scout por esporte (cadastro admin). Vitórias/empates/etc. são derivadas do resultado do jogo. */
model ScoutMetricDefinition {
  id        String   @id @default(cuid())
  sport     Sport
  key       String   @db.VarChar(64)
  label     String   @db.VarChar(120)
  sortOrder Int      @default(0)
  /** Métrica desativada pelo admin — não entra em jogos/ranking novos; histórico permanece. */
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  enabledInGroups GroupEnabledScout[]
  gameStats       GameScoutStat[]

  @@unique([sport, key])
  @@index([sport])
  @@index([sport, isActive])
  @@map("scout_metric_definitions")
}

model GroupEnabledScout {
  id                      String                @id @default(cuid())
  groupId                 String
  group                   Group                 @relation(fields: [groupId], references: [id], onDelete: Cascade)
  scoutMetricDefinitionId String
  definition              ScoutMetricDefinition @relation(fields: [scoutMetricDefinitionId], references: [id], onDelete: Cascade)

  @@unique([groupId, scoutMetricDefinitionId])
  @@map("group_enabled_scouts")
}

model GameScoutStat {
  id                      String                @id @default(cuid())
  gameId                  String
  game                    GroupGame             @relation(fields: [gameId], references: [id], onDelete: Cascade)
  userId                  String
  user                    User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  scoutMetricDefinitionId String
  definition              ScoutMetricDefinition @relation(fields: [scoutMetricDefinitionId], references: [id], onDelete: Cascade)
  value                   Int

  @@unique([gameId, userId, scoutMetricDefinitionId])
  @@index([gameId])
  @@map("game_scout_stats")
}
